generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model maintenance_notes {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  priority    Priority    @default(AVERAGE)
  title       String      @db.VarChar(80)
  description String      @db.VarChar(80)
  profile_id  String      @db.Uuid
  created_at  DateTime    @default(dbgenerated("LOCALTIMESTAMP")) @db.Timestamp(6)
  note_status Note_Status @default(OPEN)
  profiles    profiles    @relation(fields: [profile_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model profiles {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String              @unique(map: "unique_user_id") @db.Uuid
  name              String              @db.VarChar(80)
  role              Role                @default(OPERATOR)
  maintenance_notes maintenance_notes[]
  users             users               @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_id_fk")
}

model users {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String    @unique(map: "unique_user_email") @db.VarChar(80)
  password   String    @db.VarChar(80)
  active     Boolean   @default(true)
  created_at DateTime  @default(dbgenerated("LOCALTIMESTAMP")) @db.Timestamp(6)
  profiles   profiles?
}

enum Role {
  ADMIN
  GATEKEEPER
  PLANNER
  PROGRAMMER
  OPERATOR
}

enum Priority {
  LOW
  AVERAGE
  HIGH
  URGENT
}

enum Note_Status {
  OPEN
  PLANNING
  PROGRAMMING
  EXECUTING
  DONE
  CLOSED
}
